# BMsportBot — Environment Variables
# Copy this to sportbot.env and fill in your keys.
# NEVER commit sportbot.env to git!

# Weather APIs
OPENWEATHER_API_KEY=your_openweather_key_here
WEATHERAPI_API_KEY=your_weatherapi_key_here

# LLM — Groq is free, get a key at https://console.groq.com
GROQ_API_KEY=your_groq_key_here

# Optional alternative LLM providers (uncomment one):
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here

# Telegram Bot — create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Chat IDs — mapped to user keys from config.json
# Format: user_key:chat_id,user_key:chat_id
# Find chat IDs by messaging @userinfobot on Telegram
TELEGRAM_CHAT_IDS=martha:123456789,britt:987654321
